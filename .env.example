# research-harness works locally without API keys.
# These values are optional defaults used by the CLI.

RESEARCH_HARNESS_CORPUS_PATH=examples/corpus/research_corpus.json
RESEARCH_HARNESS_OUTPUT_DIR=outputs
RESEARCH_HARNESS_RETRIEVER=auto
RESEARCH_HARNESS_LLM_PROVIDER=auto
RESEARCH_HARNESS_LLM_MODEL=all-configured
# Optional comma-separated catalog shown by --interactive / --list-llm-models.
# Set RESEARCH_HARNESS_LLM_MODEL=all-configured to use this full pool round-robin.
RESEARCH_HARNESS_LLM_MODELS=openai/gpt-5.5,openai/gpt-5.2,anthropic/claude-opus-4-6,anthropic/claude-sonnet-4-6,anthropic/claude-sonnet-4-5,anthropic/claude-haiku-4-5,local/local-deterministic-fallback

# Real LLM agent mode. Provider can be inferred from RESEARCH_HARNESS_LLM_MODEL.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional live search integrations.
# SEARCH_API_KEY=
# LITERATURE_API_KEY=
