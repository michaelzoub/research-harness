# research-harness works locally without API keys.
# These values are optional defaults used by the CLI.

RESEARCH_HARNESS_CORPUS_PATH=examples/corpus/research_corpus.json
RESEARCH_HARNESS_OUTPUT_DIR=outputs
RESEARCH_HARNESS_RETRIEVER=auto
RESEARCH_HARNESS_LLM_PROVIDER=auto
RESEARCH_HARNESS_LLM_MODEL=gpt-4.1-mini

# Real LLM agent mode. When OPENAI_API_KEY is present and provider is auto/openai,
# proposal, judge, and synthesis agents call the OpenAI Responses API.
OPENAI_API_KEY=

# Optional live search integrations.
# SEARCH_API_KEY=
# LITERATURE_API_KEY=
